<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/app_background"
        android:fitsSystemWindows="true"
        tools:context=".ui.edit.EditTransactionFragment">

    <LinearLayout
            android:id="@+id/header_bar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp">

            <ImageButton
                    android:id="@+id/back_button"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_nav_chip"
                    android:contentDescription="@string/back"
                    android:padding="8dp"
                    android:src="@drawable/ic_editor_close_24"
                    app:tint="@color/text_primary" />
        </FrameLayout>

        <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

            <FrameLayout
                    android:id="@+id/type_toggle"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_editor_toggle_group"
                    android:padding="4dp"
                    android:stateListAnimator="@null">

                <View
                        android:id="@+id/type_toggle_thumb"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_gravity="start|center_vertical"
                        android:background="@drawable/bg_editor_toggle_selected" />

                <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="horizontal">

                    <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/expense_button"
                            android:layout_width="88dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center_vertical"
                            android:background="@android:color/transparent"
                            android:clickable="true"
                            android:focusable="true"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:lineSpacingExtra="0dp"
                            android:minHeight="0dp"
                            android:singleLine="true"
                            android:text="@string/expense"
                            android:textColor="#2D3335"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/income_button"
                            android:layout_width="88dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center_vertical"
                            android:background="@android:color/transparent"
                            android:clickable="true"
                            android:focusable="true"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:lineSpacingExtra="0dp"
                            android:minHeight="0dp"
                            android:singleLine="true"
                            android:text="@string/income"
                            android:textAlignment="center"
                            android:textColor="#5A6062"
                            android:textSize="14sp"
                            android:textStyle="normal" />
                </LinearLayout>
            </FrameLayout>
        </FrameLayout>

        <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp">

            <ImageButton
                    android:id="@+id/delete_button"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_nav_chip"
                    android:contentDescription="@string/delete_transaction"
                    android:padding="8dp"
                    android:src="@drawable/ic_editor_delete_24"
                    app:tint="@color/text_primary"
                    android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
            android:id="@+id/category_card"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/surface_elevated"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintBottom_toTopOf="@id/input_panel_card"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/header_bar">

        <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/category_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingStart="4dp"
                android:paddingTop="12dp"
                android:paddingEnd="4dp"
                android:paddingBottom="12dp"
                tools:listitem="@layout/item_category" />
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
            android:id="@+id/input_panel_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/surface_elevated"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
                android:id="@+id/input_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:orientation="vertical">

        <LinearLayout
                android:id="@+id/editor_meta_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingTop="10dp"
                android:paddingEnd="10dp"
                android:paddingBottom="6dp">

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                <EditText
                        android:id="@+id/note_input"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="16dp"
                        android:background="@android:color/transparent"
                        android:ellipsize="end"
                        android:fontFamily="sans-serif-medium"
                        android:hint="@string/note_input_hint"
                        android:imeOptions="actionDone"
                        android:inputType="textCapSentences"
                        android:maxLines="1"
                        android:padding="0dp"
                        android:textColor="#5A6062"
                        android:textColorHint="#805A6062"
                        android:textCursorDrawable="@null"
                        android:textSize="16sp" />

                <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="end|center_vertical"
                        android:orientation="horizontal">

                    <TextView
                            android:id="@+id/amount_preview"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:maxLength="10"
                            android:maxLines="1"
                            android:text="0"
                            android:textColor="#F87171"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                            android:id="@+id/currency_button"
                            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="30dp"
                            android:layout_marginStart="6dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:text="CNY"
                            android:textAllCaps="true"
                            android:textColor="#2D3335"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/app_background"
                            app:cornerRadius="15dp"
                            app:rippleColor="#335A6062" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                    android:id="@+id/date_button"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:layout_gravity="start"
                    android:layout_marginTop="2dp"
                    android:fontFamily="sans-serif-medium"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="@string/date_time_placeholder"
                    android:textAllCaps="false"
                    android:textColor="#5A6062"
                    android:textSize="13sp"
                    app:backgroundTint="@color/app_background"
                    app:cornerRadius="15dp"
                    app:rippleColor="#335A6062" />
        </LinearLayout>

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingTop="4dp"
                android:paddingEnd="8dp"
                android:paddingBottom="8dp">

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                        android:id="@+id/key_1"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="1"
                        android:textColor="#2D3335"
                        android:textSize="20sp"
                        app:backgroundTint="@color/app_background"
                        app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                        android:id="@+id/key_2"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="2"
                        android:textColor="#2D3335"
                        android:textSize="20sp"
                        app:backgroundTint="@color/app_background"
                        app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                        android:id="@+id/key_3"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="3"
                        android:textColor="#2D3335"
                        android:textSize="20sp"
                        app:backgroundTint="@color/app_background"
                        app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                        android:id="@+id/key_backspace"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:backgroundTint="@color/app_background"
                        app:cornerRadius="12dp"
                        app:icon="@drawable/ic_editor_backspace_24"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconTint="#2D3335" />
            </LinearLayout>

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                        android:id="@+id/key_4"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="4"
                        android:textColor="#2D3335"
                        android:textSize="20sp"
                        app:backgroundTint="@color/app_background"
                        app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                        android:id="@+id/key_5"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="5"
                        android:textColor="#2D3335"
                        android:textSize="20sp"
                        app:backgroundTint="@color/app_background"
                        app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                        android:id="@+id/key_6"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="6"
                        android:textColor="#2D3335"
                        android:textSize="20sp"
                        app:backgroundTint="@color/app_background"
                        app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                        android:id="@+id/key_minus"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:backgroundTint="@color/app_background"
                        app:cornerRadius="12dp"
                        app:icon="@drawable/ic_editor_remove_24"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconTint="#2D3335" />
            </LinearLayout>

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                        android:id="@+id/key_7"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="7"
                        android:textColor="#2D3335"
                        android:textSize="20sp"
                        app:backgroundTint="@color/app_background"
                        app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                        android:id="@+id/key_8"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="8"
                        android:textColor="#2D3335"
                        android:textSize="20sp"
                        app:backgroundTint="@color/app_background"
                        app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                        android:id="@+id/key_9"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="9"
                        android:textColor="#2D3335"
                        android:textSize="20sp"
                        app:backgroundTint="@color/app_background"
                        app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                        android:id="@+id/key_plus"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:backgroundTint="@color/app_background"
                        app:cornerRadius="12dp"
                        app:icon="@drawable/ic_editor_add_24"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconTint="#2D3335" />
            </LinearLayout>

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                        android:id="@+id/key_clear"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        android:padding="0dp"
                        android:maxLines="1"
                        android:text="@string/transaction_key_again"
                        android:textAllCaps="false"
                        android:textColor="#2D3335"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/app_background"
                        app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                        android:id="@+id/key_0"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="0"
                        android:textColor="#2D3335"
                        android:textSize="20sp"
                        app:backgroundTint="@color/app_background"
                        app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                        android:id="@+id/key_dot"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="."
                        android:textAllCaps="false"
                        android:textColor="#2D3335"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/app_background"
                        app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                        android:id="@+id/key_save"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        android:padding="0dp"
                        android:maxLines="1"
                        android:text="@string/save"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:backgroundTint="#F87171"
                        app:cornerRadius="12dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>

