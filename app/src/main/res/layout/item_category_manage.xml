<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        app:cardBackgroundColor="@color/surface_elevated"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="6dp"
            android:paddingEnd="8dp">

        <!-- Drag handle -->
        <ImageView
                android:id="@+id/drag_handle"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="4dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_dashboard_menu_24"
                app:tint="#C0C8CC" />

        <!-- Icon container -->
        <FrameLayout
                android:id="@+id/category_icon_container"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_editor_category_icon_unselected">

            <ImageView
                    android:id="@+id/category_icon_image"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:visibility="gone"
                    tools:src="@drawable/ic_dashboard_restaurant_24" />

            <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/category_icon_symbol"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="@font/material_symbols_outlined_static"
                    android:fontFeatureSettings="'liga'"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:letterSpacing="0"
                    android:textSize="21sp"
                    android:visibility="gone"
                    tools:text="restaurant" />
        </FrameLayout>

        <!-- Category name -->
        <TextView
                android:id="@+id/category_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                tools:text="Meals" />

        <!-- Delete button -->
        <ImageButton
                android:id="@+id/delete_button"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/delete"
                android:padding="6dp"
                android:src="@drawable/ic_editor_close_24"
                app:tint="#C0C8CC" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
