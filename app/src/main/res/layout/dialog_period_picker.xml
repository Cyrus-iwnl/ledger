<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/period_picker_overlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/insights_black_25"
    android:clickable="true"
    android:focusable="true"
    android:paddingStart="24dp"
    android:paddingEnd="24dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/period_picker_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:stateListAnimator="@null"
        app:cardBackgroundColor="@color/insights_surface_container_lowest"
        app:cardCornerRadius="32dp"
        app:cardElevation="0dp"
        app:rippleColor="@android:color/transparent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/period_picker_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_family"
                    android:includeFontPadding="false"
                    android:textColor="@color/insights_on_surface"
                    android:textFontWeight="800"
                    android:textSize="18sp" />

                <LinearLayout
                    android:id="@+id/period_picker_scope_group"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@color/insights_surface_container_low"
                    android:orientation="horizontal"
                    android:padding="4dp"
                    android:visibility="gone">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/period_picker_month_toggle"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:elevation="0dp"
                        android:fontFamily="@font/inter_family"
                        android:includeFontPadding="false"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:stateListAnimator="@null"
                        android:textAllCaps="false"
                        android:textColor="@color/insights_on_surface"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/period_picker_year_toggle"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:elevation="0dp"
                        android:fontFamily="@font/inter_family"
                        android:includeFontPadding="false"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:stateListAnimator="@null"
                        android:textAllCaps="false"
                        android:textColor="@color/insights_on_surface"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/period_picker_all_toggle"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:elevation="0dp"
                        android:fontFamily="@font/inter_family"
                        android:includeFontPadding="false"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:stateListAnimator="@null"
                        android:textAllCaps="false"
                        android:textColor="@color/insights_on_surface"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/period_picker_nav"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingTop="8dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp"
                android:visibility="gone">

                <com.example.account.ui.insights.MaterialSymbolTextView
                    android:id="@+id/period_picker_prev"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="chevron_left"
                    android:textColor="@color/insights_on_surface_variant"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/period_picker_nav_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/inter_family"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:textColor="@color/insights_on_surface"
                    android:textFontWeight="700"
                    android:textSize="14sp" />

                <com.example.account.ui.insights.MaterialSymbolTextView
                    android:id="@+id/period_picker_next"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="chevron_right"
                    android:textColor="@color/insights_on_surface_variant"
                    android:textSize="16sp" />
            </LinearLayout>

            <GridLayout
                android:id="@+id/period_picker_options"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:orientation="horizontal" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/period_picker_confirm_all"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"
                android:elevation="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:stateListAnimator="@null"
                android:text="@string/dialog_apply"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:backgroundTint="@color/primary_accent"
                app:cornerRadius="22dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
